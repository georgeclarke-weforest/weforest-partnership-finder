# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Netlify Emails (Postmark) — required for "Email me this partnership"
NETLIFY_EMAILS_PROVIDER=postmark
NETLIFY_EMAILS_PROVIDER_API_KEY=your_postmark_server_api_token
NETLIFY_EMAILS_SECRET=any_long_random_string

# The verified Postmark sender address
PARTNERSHIP_FROM_EMAIL=george.clarke@weforest.org

# Optional: BCC every lead submission to an internal address
# PARTNERSHIP_NOTIFY_EMAIL=partnerships@weforest.org

# Optional: rate limiting (requests per minute per IP)
# RATE_LIMIT_RPM=10
